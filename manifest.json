{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.7.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "ui.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "cache.js",
        "inject.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}
