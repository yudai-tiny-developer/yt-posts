{
  "manifest_version": 3,
  "name": "YouTube Subscribed Posts Viewer",
  "version": "0.3.0",
  "description": "YouTube Subscribed Posts Viewer",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "ui.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "cache.js",
        "inject.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}